{
  "name": "prisoner-content-hub-backend-e2e",
  "private": true,
  "description": "Playwright end-to-end tests for prisoner-content-hub-backend",
  "scripts": {
    "test:e2e": "playwright test -c tests/e2e/playwright.config.ts",
    "test:e2e:all": "playwright test --workers=1 -c tests/e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --headed -c tests/e2e/playwright.config.ts",
    "test:e2e:debug": "playwright test --debug -c tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --ui -c tests/e2e/playwright.config.ts",
    "test:e2e:report": "playwright show-report",
    "typecheck:e2e": "tsc --noEmit -p tests/e2e/tsconfig.json",
    "test:all": "npm run typecheck:e2e && npm run test:e2e:all"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
